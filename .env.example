# Firebase Configuration — copy this to .env and fill in your values
# .env is gitignored and will NOT be uploaded to GitHub
#
# How to get these values:
#   1. Go to Firebase Console → Project Settings
#   2. Copy the config values for each platform
#
# Usage:
#   ./run.sh                          (auto-loads .env)
#   flutter run --dart-define-from-file=.env

# ─── Common ───
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=

# ─── Web ───
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_MEASUREMENT_ID=

# ─── Android ───
FIREBASE_ANDROID_API_KEY=
FIREBASE_ANDROID_APP_ID=

# ─── iOS ───
FIREBASE_IOS_API_KEY=
FIREBASE_IOS_APP_ID=
FIREBASE_IOS_CLIENT_ID=

# ─── macOS ───
FIREBASE_MACOS_API_KEY=
FIREBASE_MACOS_APP_ID=
FIREBASE_MACOS_CLIENT_ID=

# ─── Windows ───
FIREBASE_WINDOWS_API_KEY=
FIREBASE_WINDOWS_APP_ID=
FIREBASE_WINDOWS_AUTH_DOMAIN=
FIREBASE_WINDOWS_MEASUREMENT_ID=
